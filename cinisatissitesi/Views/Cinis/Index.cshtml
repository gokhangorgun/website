@model IEnumerable<cinisatissitesi.Models.Cini>

@{
    ViewData["Title"] = "Admin Panel";
}

<div class="admin-page container py-5">
    <div class="admin-header shadow-sm">
        <div>
            <span class="admin-badge">Yönetim Paneli</span>
            <h1>Çini Ürün Yönetimi</h1>
            <p>Ürün ekleme, düzenleme ve silme işlemlerini buradan yönetebilirsiniz.</p>
        </div>

        <div class="admin-header-actions">
            <a asp-action="Create" class="btn new-btn">+ Yeni Çini Ekle</a>
            <a asp-controller="Account" asp-action="Logout" class="btn logout-btn">Çıkış Yap</a>
        </div>
    </div>

    <div class="admin-table-card shadow-sm mt-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead>
                    <tr>
                        <th>Ürün Adı</th>
                        <th>Açıklama</th>
                        <th>Fiyat</th>
                        <th>Stok</th>
                        <th>Kategori</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Ad</td>
                                <td>
                                    @(string.IsNullOrEmpty(item.Aciklama)
                                                                ? "Açıklama yok"
                                                                : item.Aciklama.Length > 50
                                                                ? item.Aciklama.Substring(0, 50) + "..."
                                                                : item.Aciklama)
                                </td>
                                <td>@item.Fiyat ₺</td>
                                <td>@item.Stok</td>
                                <td>@item.Kategori</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn action-btn detail-btn">Detay</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn action-btn edit-btn">Düzenle</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn action-btn delete-btn">Sil</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                Henüz ürün eklenmemiş.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(180deg, #f8fafc 0%, #eef6f7 100%);
    }

    .admin-page {
        padding-top: 30px;
        padding-bottom: 40px;
    }

    .admin-header {
        background: linear-gradient(135deg, #0f172a, #1d4ed8, #0f766e);
        color: white;
        border-radius: 24px;
        padding: 32px;
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: center;
        flex-wrap: wrap;
    }

    .admin-badge {
        display: inline-block;
        background: rgba(255,255,255,0.14);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .admin-header h1 {
        margin: 0 0 8px 0;
        font-size: 34px;
        font-weight: 800;
    }

    .admin-header p {
        margin: 0;
        opacity: 0.92;
    }

    .admin-header-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .new-btn, .logout-btn {
        border: none;
        border-radius: 14px;
        padding: 12px 18px;
        font-weight: 600;
    }

    .new-btn {
        background: white;
        color: #0f172a;
    }

    .logout-btn {
        background: rgba(255,255,255,0.14);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
    }

        .new-btn:hover,
        .logout-btn:hover {
            opacity: 0.94;
        }

    .admin-table-card {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .admin-table thead {
        background: #f8fafc;
    }

    .admin-table th {
        color: #0f172a;
        font-weight: 700;
        padding: 18px 16px;
        border-bottom: 1px solid #e2e8f0;
    }

    .admin-table td {
        padding: 18px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #eef2f7;
        color: #334155;
    }

    .action-btn {
        border-radius: 12px;
        padding: 8px 12px;
        font-size: 14px;
        font-weight: 600;
        margin-left: 6px;
    }

    .detail-btn {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

    .edit-btn {
        background: #ecfeff;
        color: #0f766e;
        border: 1px solid #99f6e4;
    }

    .delete-btn {
        background: #fff1f2;
        color: #e11d48;
        border: 1px solid #fecdd3;
    }

    @@media (max-width: 768px) {
        .admin-header h1 {
            font-size: 28px;
        }

        .action-btn {
            margin-top: 6px;
            margin-left: 0;
        }
    }
</style>