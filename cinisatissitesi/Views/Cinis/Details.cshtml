@model cinisatissitesi.Models.Cini

@{
    ViewData["Title"] = "Ürün Detayı";
}

<div class="container py-5">
    <div class="detail-card shadow-sm">
        <div class="row g-4 align-items-center">
            <div class="col-md-5">
                @if (!string.IsNullOrEmpty(Model.ResimUrl))
                {
                    <img src="@Model.ResimUrl" alt="@Model.Ad" class="img-fluid detail-image" />
                }
                else
                {
                    <div class="no-image">Resim Yok</div>
                }
            </div>

            <div class="col-md-7">
                <span class="detail-badge">Ürün Bilgisi</span>
                <h1>@Model.Ad</h1>
                <p class="detail-desc">@Model.Aciklama</p>

                <div class="info-grid mt-4">
                    <div class="info-item"><strong>Kategori:</strong> @Model.Kategori</div>
                    <div class="info-item"><strong>Fiyat:</strong> @Model.Fiyat ₺</div>
                    <div class="info-item"><strong>Stok:</strong> @Model.Stok</div>
                    <div class="info-item"><strong>ID:</strong> @Model.Id</div>
                </div>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn edit-btn">Düzenle</a>
                    <a asp-action="Index" class="btn back-btn">Listeye Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .detail-card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        border: 1px solid #e2e8f0;
    }

    .detail-image {
        width: 100%;
        height: 360px;
        object-fit: cover;
        border-radius: 20px;
    }

    .no-image {
        height: 360px;
        background: #f1f5f9;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        font-weight: 600;
    }

    .detail-badge {
        display: inline-block;
        background: #ecfeff;
        color: #0f766e;
        border: 1px solid #99f6e4;
        padding: 7px 13px;
        border-radius: 999px;
        font-size: 13px;
        margin-bottom: 14px;
        font-weight: 700;
    }

    .detail-card h1 {
        font-size: 34px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .detail-desc {
        color: #64748b;
        line-height: 1.8;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
    }

    .info-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px;
    }

    .edit-btn {
        background: linear-gradient(135deg, #0f766e, #1d4ed8);
        color: white;
        border: none;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 600;
    }

    .back-btn {
        background: #f8fafc;
        color: #0f172a;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr;
        }

        .detail-card h1 {
            font-size: 28px;
        }
    }
</style>