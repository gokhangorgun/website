@model cinisatissitesi.Models.Cini

@{
    ViewData["Title"] = "Ürün Detayı";
}

<div class="detail-page">
    <div class="container py-5">
        <div class="detail-card shadow-lg">
            <div class="row g-0">
                <div class="col-lg-6">
                    <div class="detail-image-wrapper">
                        @if (!string.IsNullOrEmpty(Model.ResimUrl))
                        {
                            <img src="@Model.ResimUrl" alt="@Model.Ad" class="detail-image" />
                        }
                        else
                        {
                            <div class="no-image">
                                <span>Resim Yok</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="detail-content">
                        <span class="detail-badge">Özel Koleksiyon</span>

                        <h1>@Model.Ad</h1>

                        <p class="detail-desc">
                            @Model.Aciklama
                        </p>

                        <div class="detail-info-grid">
                            <div class="info-box">
                                <small>Fiyat</small>
                                <strong>@Model.Fiyat ₺</strong>
                            </div>

                            <div class="info-box">
                                <small>Kategori</small>
                                <strong>@Model.Kategori</strong>
                            </div>

                            <div class="info-box">
                                <small>Stok</small>
                                <strong>@Model.Stok</strong>
                            </div>

                            <div class="info-box">
                                <small>Ürün No</small>
                                <strong>#@Model.Id</strong>
                            </div>
                        </div>

                        <div class="detail-actions">
                            <a asp-controller="Home" asp-action="Index" class="btn back-btn">Mağazaya Dön</a>
                       
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(180deg, #f8fafc 0%, #eef6f7 100%);
    }

    .detail-page {
        min-height: 100vh;
        padding-bottom: 40px;
    }

    .detail-card {
        background: white;
        border-radius: 28px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .detail-image-wrapper {
        height: 100%;
        min-height: 560px;
        background: #f1f5f9;
    }

    .detail-image {
        width: 100%;
        height: 100%;
        min-height: 560px;
        object-fit: cover;
        display: block;
    }

    .no-image {
        width: 100%;
        height: 100%;
        min-height: 560px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        font-size: 20px;
        font-weight: 600;
    }

    .detail-content {
        padding: 42px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
    }

    .detail-badge {
        display: inline-block;
        width: fit-content;
        background: #ecfeff;
        color: #0f766e;
        border: 1px solid #99f6e4;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .detail-content h1 {
        font-size: 42px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 18px;
    }

    .detail-desc {
        color: #64748b;
        font-size: 16px;
        line-height: 1.9;
        margin-bottom: 28px;
    }

    .detail-info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        margin-bottom: 30px;
    }

    .info-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 18px;
    }

        .info-box small {
            display: block;
            color: #64748b;
            margin-bottom: 6px;
            font-size: 13px;
        }

        .info-box strong {
            color: #0f172a;
            font-size: 20px;
            font-weight: 700;
        }

    .detail-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .back-btn {
        background: #f8fafc;
        color: #0f172a;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 600;
    }

        .back-btn:hover {
            color: #0f172a;
            background: #f1f5f9;
        }

    .order-btn {
        background: linear-gradient(135deg, #0f766e, #1d4ed8);
        color: white;
        border: none;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 600;
    }

        .order-btn:hover {
            color: white;
            opacity: 0.95;
        }

    @@media (max-width: 991px) {
        .detail-image-wrapper,
        .detail-image,
        .no-image {
            min-height: 360px;
        }

        .detail-content {
            padding: 30px 24px;
        }

            .detail-content h1 {
                font-size: 32px;
            }
    }

    @@media (max-width: 576px) {
        .detail-info-grid {
            grid-template-columns: 1fr;
        }

        .detail-content h1 {
            font-size: 28px;
        }
    }
</style>